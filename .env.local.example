# Supabase project URL — find it in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — NEVER expose this in the browser or commit it
# Used only in server-side code (e.g., admin operations, DB migrations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
